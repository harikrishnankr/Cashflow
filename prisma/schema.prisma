// ============================================================
// Prisma Schema — Expense Tracker (Next.js + Supabase)
// ============================================================
// Key design decisions:
//  - Uses Supabase Auth (auth.users) via unsupported() type for userId
//  - Soft deletes on Expense/Income for audit trail
//  - Enum-driven category + frequency types for query performance
//  - Composite indexes for common dashboard query patterns
//  - Notification preferences stored as a single JSON blob (flexible)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum ExpenseCategory {
  FOOD
  TRANSPORT
  BILLS
  ENTERTAINMENT
  HEALTH
  SHOPPING
  EDUCATION
  TRAVEL
  HOUSING
  PERSONAL_CARE
  INVESTMENTS
  SAVINGS
  OTHER
}

enum IncomeSource {
  SALARY
  FREELANCE
  INVESTMENTS
  RENTAL
  BUSINESS
  GIFT
  OTHER
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum NotificationType {
  BILL_REMINDER
  BUDGET_ALERT
  WEEKLY_SUMMARY
  MONTHLY_SUMMARY
  RECURRING_DUE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

// ─────────────────────────────────────────────
// USER PROFILE
// Links to Supabase auth.users (managed externally)
// ─────────────────────────────────────────────
model UserProfile {
  // Maps to the UUID from Supabase auth.users
  id        String   @id @db.Uuid
  email     String   @unique
  name      String // This field should have min and max length
  currency  String   @default("USD") // ISO 4217 code
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  expenses             Expense[]
  incomes              Income[]
  budgets              Budget[]
  recurringExpenses    RecurringExpense[]
  recurringIncomes     RecurringIncome[]
  notifications        Notification[]
  notificationSettings NotificationSettings?

  @@map("user_profiles")
}

// ─────────────────────────────────────────────
// EXPENSE MANAGEMENT
// ─────────────────────────────────────────────
model Expense {
  id         String          @id @default(cuid())
  userId     String          @db.Uuid
  amount     Decimal         @db.Decimal(12, 2) // Supports up to 9,999,999,999.99
  category   ExpenseCategory
  notes      String?         @db.Text
  date       DateTime        @db.Date // Store date only for grouping queries
  receiptUrl String? // Supabase Storage URL

  // Soft delete — preserves history & analytics
  deletedAt DateTime?

  // Link to the recurring template that spawned this entry (nullable)
  recurringExpenseId String?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id])

  // Relations
  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes optimized for dashboard & analytics queries
  @@index([userId, date]) // Most common: "my expenses this month"
  @@index([userId, category]) // Category breakdown
  @@index([userId, date, category]) // Category breakdown for a period
  @@index([deletedAt]) // Quickly filter soft-deleted rows
  @@map("expenses")
}

// ─────────────────────────────────────────────
// RECURRING EXPENSES (templates)
// e.g. rent, Netflix, EMI
// ─────────────────────────────────────────────
model RecurringExpense {
  id                 String             @id @default(cuid())
  userId             String             @db.Uuid
  amount             Decimal            @db.Decimal(12, 2)
  category           ExpenseCategory
  description        String
  notes              String?            @db.Text
  frequency          RecurringFrequency
  startDate          DateTime           @db.Date
  endDate            DateTime?          @db.Date // Null = indefinite
  nextDueDate        DateTime           @db.Date
  isActive           Boolean            @default(true)
  reminderDaysBefore Int                @default(3)

  // Relations
  user     UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[] // Expenses spawned from this template

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([nextDueDate, isActive]) // For cron jobs / reminder triggers
  @@map("recurring_expenses")
}

// ─────────────────────────────────────────────
// INCOME TRACKING
// ─────────────────────────────────────────────
model Income {
  id     String       @id @default(cuid())
  userId String       @db.Uuid
  amount Decimal      @db.Decimal(12, 2)
  source IncomeSource
  notes  String?      @db.Text
  date   DateTime     @db.Date

  deletedAt DateTime?

  recurringIncomeId String?
  recurringIncome   RecurringIncome? @relation(fields: [recurringIncomeId], references: [id])

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, source])
  @@map("incomes")
}

model RecurringIncome {
  id          String             @id @default(cuid())
  userId      String             @db.Uuid
  amount      Decimal            @db.Decimal(12, 2)
  source      IncomeSource
  description String
  frequency   RecurringFrequency
  startDate   DateTime           @db.Date
  endDate     DateTime?          @db.Date
  nextDueDate DateTime           @db.Date
  isActive    Boolean            @default(true)

  user    UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes Income[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([nextDueDate, isActive])
  @@map("recurring_incomes")
}

// ─────────────────────────────────────────────
// BUDGET MANAGEMENT
// ─────────────────────────────────────────────
model Budget {
  id     String @id @default(cuid())
  userId String @db.Uuid
  name   String

  // Null category = overall spending limit for the period
  category ExpenseCategory?
  amount   Decimal          @db.Decimal(12, 2)
  period   BudgetPeriod

  // Period start anchor — e.g. 2024-01-01 for January monthly budget
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  // Alert threshold — e.g. 0.80 fires alert at 80% spent
  alertThreshold Decimal @default(0.80) @db.Decimal(3, 2)
  isActive       Boolean @default(true)

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevent duplicate category budgets for the same period
  @@unique([userId, category, period, periodStart])
  @@index([userId, isActive, periodStart])
  @@map("budgets")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id      String              @id @default(cuid())
  userId  String              @db.Uuid
  type    NotificationType
  channel NotificationChannel @default(IN_APP)
  title   String
  body    String              @db.Text

  // Flexible metadata: budgetId, recurringId, amount, etc.
  metadata Json?
  isRead   Boolean   @default(false)
  readAt   DateTime?

  // When the notification should fire (for scheduled ones)
  scheduledAt DateTime?
  sentAt      DateTime?

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([scheduledAt]) // For notification job scheduling
  @@map("notifications")
}

// ─────────────────────────────────────────────
// NOTIFICATION SETTINGS (per user preferences)
// ─────────────────────────────────────────────
model NotificationSettings {
  id     String @id @default(cuid())
  userId String @unique @db.Uuid

  billReminders  Boolean @default(true)
  budgetAlerts   Boolean @default(true)
  weeklySummary  Boolean @default(true)
  monthlySummary Boolean @default(true)

  // Preferred channels
  emailEnabled Boolean @default(false)
  pushEnabled  Boolean @default(false)
  inAppEnabled Boolean @default(true)

  // Weekly summary day: 0=Sunday … 6=Saturday
  weeklySummaryDay Int @default(1)

  // Monthly summary day of month: 1–28
  monthlySummaryDay Int @default(1)

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}
