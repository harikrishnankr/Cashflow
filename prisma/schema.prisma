// ============================================================
// Prisma Schema — CashFlow (Next.js + Supabase PostgreSQL)
// ============================================================
// Auth strategy:
//  - Custom email/password auth (argon2 + JWT + refresh tokens)
//  - Cookie-based: access token (15 min) + refresh token (7d / 30d)
//  - Google OAuth ready via googleId field
//  - Refresh tokens stored as SHA-256 hashes — raw token lives only
//    in the httpOnly cookie, never in plaintext in the database
//
// Prisma 7 connection config is in prisma.config.ts (not here):
//  - migrations → DIRECT_URL (direct Supabase connection, bypasses PgBouncer)
//  - runtime    → DATABASE_URL via PrismaPg adapter in src/lib/prisma.ts
//
// ID strategy:
//  - User.id        → UUID  (goes inside JWTs; must not be guessable)
//  - Everything else → Int autoincrement (smaller, faster, easier to read;
//    enumeration risk is irrelevant because every route filters by userId)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────
enum ExpenseCategory {
  FOOD
  TRANSPORT
  BILLS
  ENTERTAINMENT
  HEALTH
  SHOPPING
  EDUCATION
  TRAVEL
  HOUSING
  PERSONAL_CARE
  INVESTMENTS
  SAVINGS
  OTHER
}

enum IncomeSource {
  SALARY
  FREELANCE
  INVESTMENTS
  RENTAL
  BUSINESS
  GIFT
  OTHER
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum NotificationType {
  BILL_REMINDER
  BUDGET_ALERT
  WEEKLY_SUMMARY
  MONTHLY_SUMMARY
  RECURRING_DUE
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

// ─────────────────────────────────────────────
// USER
// UUID because id is embedded in JWTs and must not be guessable.
// passwordHash is nullable to support OAuth-only accounts.
// ─────────────────────────────────────────────
model User {
  id    String @id @default(uuid()) @db.Uuid
  email String @unique @db.VarChar(255)
  name  String @db.VarChar(100)

  // Credentials — null when the account was created via OAuth only
  passwordHash String? @db.Text

  // OAuth — populated on Google sign-in (future)
  googleId  String? @unique @db.VarChar(255)
  avatarUrl String? @db.Text

  // Profile preferences
  currency String @default("USD") @db.VarChar(3)
  timezone String @default("UTC") @db.VarChar(50)

  // Onboarding state
  hasOnBoarded         Boolean      @default(false)
  primaryIncomeSource  IncomeSource?

  // Account state
  emailVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens        RefreshToken[]
  expenses             Expense[]
  incomes              Income[]
  budgets              Budget[]
  recurringExpenses    RecurringExpense[]
  recurringIncomes     RecurringIncome[]
  notifications        Notification[]
  notificationSettings NotificationSettings?

  @@map("users")
}

// ─────────────────────────────────────────────
// REFRESH TOKEN
// Enables cookie-based auth with persistent sessions.
//
// Flow:
//  1. Login → generate random token → SHA-256 hash → store here
//  2. Send raw token in httpOnly cookie (refresh_token)
//  3. On refresh → hash incoming cookie → lookup tokenHash → verify
//  4. Logout → set revokedAt (or hard-delete)
//  5. Nightly job → delete rows where expiresAt < NOW()
//
// rememberMe=false → 7-day expiry
// rememberMe=true  → 30-day expiry
// ─────────────────────────────────────────────
model RefreshToken {
  id Int @id @default(autoincrement())

  userId    String @db.Uuid
  // SHA-256 hex digest of the raw token — never stored in plaintext
  tokenHash String @unique @db.VarChar(64)

  rememberMe Boolean  @default(false)
  expiresAt  DateTime

  // Soft-revoke: set on logout or when the token is rotated
  revokedAt DateTime?

  // Optional security metadata for audit / anomaly detection
  userAgent String? @db.Text
  ipAddress String? @db.VarChar(45) // handles IPv4 and IPv6

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt]) // used by cleanup job
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// EXPENSE MANAGEMENT
// ─────────────────────────────────────────────
model Expense {
  id         Int             @id @default(autoincrement())
  userId     String          @db.Uuid
  amount     Decimal         @db.Decimal(12, 2)
  category   ExpenseCategory
  notes      String?         @db.Text
  date       DateTime        @db.Date
  receiptUrl String?

  deletedAt DateTime?

  recurringExpenseId Int?
  recurringExpense   RecurringExpense? @relation(fields: [recurringExpenseId], references: [id])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, date, category])
  @@index([deletedAt])
  @@map("expenses")
}

// ─────────────────────────────────────────────
// RECURRING EXPENSES (templates)
// ─────────────────────────────────────────────
model RecurringExpense {
  id                 Int                @id @default(autoincrement())
  userId             String             @db.Uuid
  amount             Decimal            @db.Decimal(12, 2)
  category           ExpenseCategory
  description        String
  notes              String?            @db.Text
  frequency          RecurringFrequency
  startDate          DateTime           @db.Date
  endDate            DateTime?          @db.Date
  nextDueDate        DateTime           @db.Date
  isActive           Boolean            @default(true)
  reminderDaysBefore Int                @default(3)

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([nextDueDate, isActive])
  @@map("recurring_expenses")
}

// ─────────────────────────────────────────────
// INCOME TRACKING
// ─────────────────────────────────────────────
model Income {
  id     Int          @id @default(autoincrement())
  userId String       @db.Uuid
  amount Decimal      @db.Decimal(12, 2)
  source IncomeSource
  notes  String?      @db.Text
  date   DateTime     @db.Date

  deletedAt DateTime?

  recurringIncomeId Int?
  recurringIncome   RecurringIncome? @relation(fields: [recurringIncomeId], references: [id])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, source])
  @@map("incomes")
}

model RecurringIncome {
  id          Int                @id @default(autoincrement())
  userId      String             @db.Uuid
  amount      Decimal            @db.Decimal(12, 2)
  source      IncomeSource
  description String
  frequency   RecurringFrequency
  startDate   DateTime           @db.Date
  endDate     DateTime?          @db.Date
  nextDueDate DateTime           @db.Date
  isActive    Boolean            @default(true)

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes Income[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, isActive])
  @@index([nextDueDate, isActive])
  @@map("recurring_incomes")
}

// ─────────────────────────────────────────────
// BUDGET MANAGEMENT
// ─────────────────────────────────────────────
model Budget {
  id     Int    @id @default(autoincrement())
  userId String @db.Uuid
  name   String

  category ExpenseCategory?
  amount   Decimal          @db.Decimal(12, 2)
  period   BudgetPeriod

  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  alertThreshold Decimal @default(0.80) @db.Decimal(3, 2)
  isActive       Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, period, periodStart])
  @@index([userId, isActive, periodStart])
  @@map("budgets")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────
model Notification {
  id      Int                 @id @default(autoincrement())
  userId  String              @db.Uuid
  type    NotificationType
  channel NotificationChannel @default(IN_APP)
  title   String
  body    String              @db.Text

  metadata Json?
  isRead   Boolean   @default(false)
  readAt   DateTime?

  scheduledAt DateTime?
  sentAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([scheduledAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// NOTIFICATION SETTINGS (per-user preferences)
// One row per user — userId doubles as the natural key,
// so no separate surrogate id is needed.
// ─────────────────────────────────────────────
model NotificationSettings {
  userId String @id @db.Uuid

  billReminders  Boolean @default(true)
  budgetAlerts   Boolean @default(true)
  weeklySummary  Boolean @default(true)
  monthlySummary Boolean @default(true)

  emailEnabled Boolean @default(false)
  pushEnabled  Boolean @default(false)
  inAppEnabled Boolean @default(true)

  weeklySummaryDay  Int @default(1)
  monthlySummaryDay Int @default(1)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@map("notification_settings")
}
